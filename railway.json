{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE"
    },
    "deploy": {
        "startCommand": "sh -c 'gunicorn --bind 0.0.0.0:$PORT src.main:app'",
        "healthcheckPath": "/api/honeypot",
        "healthcheckTimeout": 100,
        "restartPolicyType": "ON_FAILURE"
    }
}